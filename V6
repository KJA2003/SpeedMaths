// ================================================================
// LEARN — LEVEL SYSTEM
// ================================================================

// ---- Level generator ----
// Each level is defined by: ops, ranges, target (correct answers), timeSecs, description
// Levels 1-10000+ are generated algorithmically with smooth progression

function lerp(a, b, t) { return Math.round(a + (b - a) * Math.min(1, Math.max(0, t))); }

function getLevel(n) {
  var level = { n: n, ops: [], addA: [2,10], addB: [2,10], mulA: [2,5], mulB: [2,10], target: 5, timeSecs: 60, desc: '' };

  // Focused "challenge" levels that appear periodically to mix things up.
  // These are fixed and override the phase system.
  // ================================================================
  // LEVEL DESIGN
  // ================================================================
  // Calibration:
  //   Level 1   = ridiculously easy (addition 1-5)
  //   Level 50  = average person, no training needed
  //   Level 100 = needs some practice
  //   Level 200 = getting serious, ~30 correct in 2min
  //   Level 350 = strong player, ~80 correct
  //   Level 500 = almost impossible, ~200 correct (world record pace)
  //
  // Operations introduced gradually, then cycled for variety.
  // mulA (left) grows from 2 toward 50 by level 500.
  // mulB (right) capped at 100.

  // ── Smooth interpolators for ranges and targets ──
  // ================================================================
  // LEVEL GENERATION — always default ranges, difficulty via ops+targets+time
  //
  // Key insight: add/sub is ~30% faster than mul/div for most people.
  // So a level with mul/div needs a lower target than one with add/sub
  // to feel equally hard. We apply a difficulty weight per op set.
  //
  // "Pace" = answers per second needed.
  // Level 1:   pace 0.07 (1 per 15s) — trivially easy
  // Level 50:  pace 0.25 (1 per 4s)  — easy
  // Level 100: pace 0.32             — needs practice
  // Level 200: pace 0.42             — getting serious
  // Level 350: pace 0.70             — strong player
  // Level 500: pace 1.67             — world record (200 in 2min)
  // ================================================================

  // Pace curve — answers per second required
  // Uses flerp (float lerp) — NOT the global lerp which rounds to int
  function flerp(a, b, t) { return a + (b - a) * Math.min(1, Math.max(0, t)); }
  function paceForLevel(n) {
    if (n <= 10)  return flerp(0.12,  0.17,  (n-1)/9);
    if (n <= 30)  return flerp(0.17,  0.22,  (n-10)/20);
    if (n <= 60)  return flerp(0.22,  0.27,  (n-30)/30);
    if (n <= 100) return flerp(0.25,  0.33,  (n-60)/40);
    if (n <= 200) return flerp(0.33,  0.50,  (n-100)/100);
    if (n <= 350) return flerp(0.50,  0.83,  (n-200)/150);
    if (n <= 500) return flerp(0.83,  1.67,  (n-350)/150);
    return Math.min(3.0, flerp(1.67, 3.0, (n-500)/500));
  }

  // Op difficulty weight (relative to all-four = 1.0)
  // Add/sub is easier, so we demand more answers from those levels.
  // Mul/div is harder, so we demand fewer.
  function opWeight(ops) {
    var s = ops.slice().sort().join(',');
    if (s === 'addition')                              return 0.85; // slightly easier
    if (s === 'addition,subtraction')                  return 0.90;
    if (s === 'multiplication')                        return 1.10; // slightly harder
    if (s === 'division')                              return 1.15;
    if (s === 'multiplication,division')               return 1.10;
    if (s === 'addition,multiplication')               return 1.00;
    if (s === 'addition,division,multiplication,subtraction') return 1.00; // all four
    return 1.00;
  }

  // Time: short at early levels, ramps to 2min, stays there
  function timeForLevel(n) {
    if (n <= 5)   return 20;
    if (n <= 15)  return 30;
    if (n <= 30)  return 45;
    if (n <= 50)  return 60;
    if (n <= 80)  return 90;
    return 120;
  }

  // Op set cycles — introduce ops gradually, then mix with ~50% all-four
  function opsForLevel(n) {
    var ALL    = ['addition','subtraction','multiplication','division'];
    var ADDSUB = ['addition','subtraction'];
    var MULDIV = ['multiplication','division'];
    var MUL    = ['multiplication'];
    var DIV    = ['division'];
    var ADD    = ['addition'];

    if (n <= 3)  return ADD;
    if (n <= 8)  return ADDSUB;
    if (n <= 14) return ['addition','subtraction','multiplication'];
    if (n <= 18) return ALL;
    // From 19+ cycle: 4 of 8 slots = ALL (50%), others rotate
    var cycle = n % 8;
    if (cycle === 0) return ALL;
    if (cycle === 1) return ADDSUB;
    if (cycle === 2) return ALL;
    if (cycle === 3) return MULDIV;
    if (cycle === 4) return ALL;
    if (cycle === 5) return MUL;
    if (cycle === 6) return ALL;
    return DIV;
  }

  function descForOps(ops) {
    var sorted = ops.slice().sort().join(',');
    var map = {
      'addition':                              'Addition only',
      'subtraction':                           'Subtraction only',
      'multiplication':                        'Multiplication only',
      'division':                              'Division only',
      'addition,subtraction':                  'Addition & subtraction',
      'multiplication,division': 'Multiply' + ' & divide',
      'addition,division,multiplication,subtraction': 'All four operations',
      'addition,multiplication,subtraction':   'Add, sub & multiply'
    };
    return map[sorted] || 'Mixed operations';
  }

  var ops   = opsForLevel(n);
  var tSecs = timeForLevel(n);
  var pace  = paceForLevel(n);
  var wt    = opWeight(ops);
  // Target = pace * time / weight (harder ops = lower target needed for same difficulty)
  // pace defines 3-star "perfect run". 1-star is achievable by anyone trying.
  var star3 = Math.max(3, Math.round(pace * tSecs / wt));
  var star1 = Math.max(1, Math.round(star3 * 0.5));
  var star2 = Math.round((star1 + star3) / 2);
  // Ensure minimum gap of 2 between each star
  if (star2 < star1 + 2) star2 = star1 + 2;
  if (star3 < star2 + 2) star3 = star2 + 2;

  level.ops      = ops;
  level.addA     = [2, 100];
  level.addB     = [2, 100];
  level.mulA     = [2, 12];
  level.mulB     = [2, 100];
  level.target   = star1;
  level.star2    = star2;
  level.star3    = star3;
  level.timeSecs = tSecs;
  level.numType  = 'normal';
  level.desc     = descForOps(ops);
  return level;
}


