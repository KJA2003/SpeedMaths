window.startLearnLevel = startLearnLevel;
window.retryLearnLevel = retryLearnLevel;
})();
});
</script>
</head>
<body>

<nav class="nav">
  <button class="nav-btn active" data-page="play">Play</button>
  <button class="nav-btn" data-page="results">Results</button>
  <button class="nav-btn" data-page="history">History</button>
  <button class="nav-btn" data-page="practice">Practise</button>
  <button class="nav-btn" data-page="leaderboard">Leaderboard</button>
  <button class="nav-btn" data-page="learn">Learn</button>
</nav>

<!-- PLAY -->
<div class="page active" id="page-play">
  <!-- First-time welcome banner -->
  <div id="welcome-banner" style="display:none;width:100%;background:white;border:1px solid #ddd;padding:20px 18px;margin-bottom:20px">
    <div style="font-size:1.1rem;font-weight:700;margin-bottom:8px">Welcome to Alkaliner</div>
    <div style="font-size:0.65rem;color:#888;line-height:1.8;margin-bottom:12px">
      A mental arithmetic speed drill. Answer as many questions as you can before time runs out.<br>
      <strong style="color:#111">How to play:</strong> type your answer and press nothing — it submits automatically when correct.<br>
      Pressing backspace marks a question as trouble, which you can practise later.<br>
      Start with the default settings below, or customise the number ranges and duration.
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
      <div style="flex:1;min-width:120px;background:#f5f5f0;padding:10px 12px">
        <div style="font-size:0.55rem;letter-spacing:2px;text-transform:uppercase;color:#999;margin-bottom:4px">Play</div>
        <div style="font-size:0.62rem;color:#555;line-height:1.6">Speed drills with your settings. Results and patterns tracked after each game.</div>
      </div>
      <div style="flex:1;min-width:120px;background:#f5f5f0;padding:10px 12px">
        <div style="font-size:0.55rem;letter-spacing:2px;text-transform:uppercase;color:#999;margin-bottom:4px">Learn</div>
        <div style="font-size:0.62rem;color:#555;line-height:1.6">500 levels from trivially easy to world-record pace. Unlock levels as you go.</div>
      </div>
      <div style="flex:1;min-width:120px;background:#f5f5f0;padding:10px 12px">
        <div style="font-size:0.55rem;letter-spacing:2px;text-transform:uppercase;color:#999;margin-bottom:4px">Leaderboard</div>
        <div style="font-size:0.62rem;color:#555;line-height:1.6">Top scores from players worldwide. Only default settings count.</div>
      </div>
    </div>
  </div>

  <div id="config-screen" style="width:100%">
    <div class="section-label">Operations</div>
    <div class="ops-list">
      <div class="op-row active" data-op="addition" onclick="toggleOp(event,this)">
        <div class="op-check">&#10003;</div><div class="op-label">Addition</div>
        <div class="range-inline">
          (<input type="number" id="add-a1" value="2" onclick="stopProp(event)"> to
          <input type="number" id="add-a2" value="100" onclick="stopProp(event)">)
          + (<input type="number" id="add-b1" value="2" onclick="stopProp(event)"> to
          <input type="number" id="add-b2" value="100" onclick="stopProp(event)">)
        </div>
      </div>
      <div class="op-row active" data-op="subtraction" onclick="toggleOp(event,this)">
        <div class="op-check">&#10003;</div><div class="op-label">Subtraction</div>
        <div class="range-inline" style="color:#ccc">Addition in reverse.</div>
      </div>
      <div class="op-row active" data-op="multiplication" onclick="toggleOp(event,this)">
        <div class="op-check">&#10003;</div><div class="op-label">Multiplication</div>
        <div class="range-inline">
          (<input type="number" id="mul-a1" value="2" onclick="stopProp(event)"> to
          <input type="number" id="mul-a2" value="12" onclick="stopProp(event)">)
          x (<input type="number" id="mul-b1" value="2" onclick="stopProp(event)"> to
          <input type="number" id="mul-b2" value="100" onclick="stopProp(event)">)
        </div>
      </div>
      <div class="op-row active" data-op="division" onclick="toggleOp(event,this)">
        <div class="op-check">&#10003;</div><div class="op-label">Division</div>
        <div class="range-inline" style="color:#ccc">Multiplication in reverse.</div>
      </div>
    </div>
    <div class="section-label">Duration</div>
    <div class="duration-row">
      <button class="dur-btn" data-sec="30">30s</button>
      <button class="dur-btn" data-sec="60">1 min</button>
      <button class="dur-btn active" data-sec="120">2 min</button>
      <button class="dur-btn" data-sec="300">5 min</button>
      <button class="dur-btn" data-sec="600">10 min</button>
    </div>
    <div class="section-label">Options</div>
    <label class="toggle-row" for="pace-toggle">
      <div>
        <div class="toggle-row-label">Pace indicator</div>
        <div class="toggle-row-sub">Live bar showing your speed vs average</div>
      </div>
      <div class="toggle-switch">
        <input type="checkbox" id="pace-toggle" checked onchange="setPaceVisible(this.checked)">
        <div class="toggle-slider"></div>
      </div>
    </label>
    <button class="start-btn" onclick="startGame()">Start</button>

  </div>

  <div id="game-screen" style="display:none;width:100%;flex-direction:column;align-items:center;">
    <div class="timer-bar-wrap"><div class="timer-bar" id="timer-bar"></div></div>
    <div class="hud">
      <div><div>Time</div><div class="hud-val" id="timer-display">2:00</div></div>
      <div style="text-align:right"><div>Score</div><div class="hud-val" id="score-display">0</div></div>
    </div>
    <div class="question" id="question-display"></div>
    <input class="answer-input" id="answer-input" type="text" inputmode="numeric" autocomplete="off" spellcheck="false">
    <div class="pace-wrap" id="pace-wrap">
      <div class="pace-label" id="pace-label">vs your avg</div>
      <div class="pace-bar-wrap"><div class="pace-fill" id="pace-fill"></div></div>
      <div class="pace-number" id="pace-number"></div>
    </div>
    <button class="stop-btn" onclick="quitGame()">Stop</button>
  </div>
</div>

<!-- RESULTS -->
<div class="page" id="page-results">
  <div class="result-label">Final Score</div>
  <div class="result-score" id="final-score">0</div>
  <div class="result-sub" id="final-sub"></div>
  <div class="stats">
    <div class="stat"><div class="stat-val" id="stat-correct">0</div><div class="stat-key">Correct</div></div>
    <div class="stat"><div class="stat-val" id="stat-trouble">0</div><div class="stat-key">Trouble</div></div>
    <div class="stat"><div class="stat-val" id="stat-acc">-</div><div class="stat-key">Accuracy</div></div>
  </div>
  <div class="chart-wrap">
    <div class="chart-title">Avg. time per correct answer</div>
    <div class="chart-rows" id="chart-rows"></div>
  </div>
  <div class="btn-row">
    <button class="btn-outline" id="practice-last-btn" onclick="startPracticeFromResults()" disabled>Practice mistakes</button>
    <button class="btn-outline" onclick="showPage('play')">Play again</button>
  </div>
  <!-- Inline practice panel -->
  <div id="inline-practice" style="display:none;width:100%;margin-top:20px">
    <div style="height:1px;background:#ddd;margin-bottom:20px"></div>
    <div class="practice-meta" id="ip-progress-wrap">
      <div><div>Question</div><div class="practice-meta-val" id="ip-progress">1/5</div></div>
      <div style="text-align:right"><div>Remaining</div><div class="practice-meta-val" id="ip-remaining">5</div></div>
    </div>
    <div id="ip-tag-wrap" style="margin-bottom:12px"></div>
    <div style="display:flex;flex-direction:column;align-items:center;width:100%">
      <div class="question" id="ip-question"></div>
      <input class="answer-input" id="ip-input" type="text" inputmode="numeric" autocomplete="off" spellcheck="false">
    </div>
    <div id="ip-done" style="display:none;text-align:center;padding:24px 0">
      <div style="font-size:0.6rem;letter-spacing:3px;text-transform:uppercase;color:#999;margin-bottom:8px">Done</div>
      <div style="font-size:2.4rem;font-weight:700;margin-bottom:16px" id="ip-done-score">0/0</div>
      <button class="btn-outline" style="width:100%" onclick="closeInlinePractice()">Back to results</button>
    </div>
  </div>
</div>

<!-- HISTORY -->
<div class="page" id="page-history">
  <div id="alltime-banner" style="width:100%;background:white;border:1px solid #ddd;padding:16px 18px;margin-bottom:16px;display:none">
    <div style="font-size:0.58rem;letter-spacing:2px;text-transform:uppercase;color:#999;margin-bottom:14px">High scores <span style="font-size:0.5rem;color:#bbb;letter-spacing:1px">(default settings only)</span></div>
    <div id="highscore-rows" style="display:flex;flex-direction:column;gap:10px"></div>
  </div>
  <div class="history-controls">
    <button class="hist-btn active" onclick="setHistN(this,5)">Last 5</button>
    <button class="hist-btn" onclick="setHistN(this,10)">10</button>
    <button class="hist-btn" onclick="setHistN(this,100)">100</button>
    <button class="hist-btn" onclick="setHistN(this,99999)">All time</button>
  </div>
  <div class="graph-wrap"><div class="graph-title">Score over time (2-min equivalent)</div><canvas id="graph-score" height="120"></canvas></div>
  <div class="graph-wrap"><div class="graph-title">Accuracy % over time</div><canvas id="graph-acc" height="120"></canvas></div>
  <div class="graph-wrap"><div class="graph-title">Avg time per answer (s)</div><canvas id="graph-time" height="120"></canvas></div>
  <div class="section-label" style="margin-top:8px">Game log</div>
  <table class="history-table">
    <thead><tr><th>#</th><th>Date</th><th>Dur</th><th>Score</th><th>Acc</th><th>Avg time</th></tr></thead>
    <tbody id="history-tbody"></tbody>
  </table>
  <div class="no-history" id="no-history" style="display:none"><div style="font-size:1.5rem;margin-bottom:8px">&#9203;</div><div style="font-weight:700;margin-bottom:6px">No games yet</div><div style="font-size:0.6rem;line-height:1.7">Play your first game on the Play tab to start tracking your progress. Your scores, accuracy and average time will appear here.</div></div>
  <button class="btn-outline" style="width:100%;margin-top:4px" onclick="clearHistory()">Clear all history</button>
</div>

<!-- PRACTISE -->
<div class="page" id="page-practice">
  <!-- Patterns section -->
  <div id="patterns-list" style="width:100%"></div>
  <p class="no-patterns" id="no-patterns" style="display:none">Play more games to see patterns.</p>
  <div style="height:16px"></div>
  <div id="practice-config" style="width:100%">
    <button class="start-btn" id="practice-start-btn" onclick="startPracticeSession()">Start practice</button>
  </div>
  <div id="practice-game" style="display:none;width:100%;flex-direction:column;align-items:center;">
    <div class="practice-meta">
      <div><div>Question</div><div class="practice-meta-val" id="prac-progress">1/5</div></div>
      <div style="text-align:right"><div>Remaining</div><div class="practice-meta-val" id="prac-remaining">5</div></div>
    </div>
    <div id="practice-tag-wrap" style="margin-bottom:12px"></div>
    <div class="question" id="practice-question"></div>
    <input class="answer-input" id="practice-input" type="text" inputmode="numeric" autocomplete="off" spellcheck="false">
    <div style="margin-top:28px;text-align:center">
      <button class="btn-outline" style="width:auto;padding:8px 20px" onclick="endPracticeSession()">End practice</button>
    </div>
  </div>
  <div id="practice-done" style="display:none;width:100%;text-align:center;padding:40px 0">
    <div style="font-size:0.6rem;letter-spacing:3px;text-transform:uppercase;color:#999;margin-bottom:12px">Practice complete</div>
    <div style="font-size:3rem;font-weight:700;margin-bottom:24px" id="prac-done-score">0/0</div>
    <button class="btn-outline" style="width:100%;margin-bottom:8px" onclick="startPracticeSession()">Go again</button>
    <button class="btn-outline" style="width:100%" onclick="showPracticeConfig()">Change selection</button>
  </div>
</div>


<!-- LEADERBOARD -->
<div class="page" id="page-leaderboard">
  <div style="width:100%">
    <div id="lb-window-filters" style="display:flex;gap:4px;margin-bottom:12px;flex-wrap:wrap">
      <button class="hist-btn active" data-window="day" onclick="setLbWindow(this,'day')">Today</button>
      <button class="hist-btn" data-window="week" onclick="setLbWindow(this,'week')">This week</button>
      <button class="hist-btn" data-window="month" onclick="setLbWindow(this,'month')">This month</button>
      <button class="hist-btn" data-window="all" onclick="setLbWindow(this,'all')">All time</button>
    </div>
    <div style="display:flex;gap:4px;margin-bottom:20px;flex-wrap:wrap" id="lb-dur-filters">
      <button class="hist-btn active" data-sec="120" onclick="setLbDur(this,120)">2 min</button>
      <button class="hist-btn" data-sec="60" onclick="setLbDur(this,60)">1 min</button>
      <button class="hist-btn" data-sec="30" onclick="setLbDur(this,30)">30s</button>
      <button class="hist-btn" data-sec="300" onclick="setLbDur(this,300)">5 min</button>
      <button class="hist-btn" data-sec="600" onclick="setLbDur(this,600)">10 min</button>
    </div>
    <div id="lb-list" style="width:100%;display:flex;flex-direction:column;gap:2px"></div>
    <div id="lb-empty" style="display:none;font-size:0.65rem;color:#bbb;text-align:center;padding:32px 0">No scores yet for this period.</div>
    <div id="lb-loading" style="font-size:0.65rem;color:#bbb;text-align:center;padding:32px 0">Loading...</div>
  </div>
</div>

<!-- NAME MODAL -->
<div id="name-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:100;align-items:center;justify-content:center">
  <div style="background:white;padding:32px;max-width:320px;width:90%;text-align:center">
    <div style="font-size:0.6rem;letter-spacing:3px;text-transform:uppercase;color:#999;margin-bottom:16px">Submit your score</div>
    <div style="font-size:2.5rem;font-weight:700;margin-bottom:8px" id="modal-score"></div>
    <div style="font-size:0.65rem;color:#999;margin-bottom:20px" id="modal-sub"></div>
    <input id="name-input" type="text" maxlength="20" placeholder="Your name"
      style="width:100%;border:none;border-bottom:2px solid #111;font-family:'Roboto Mono',monospace;font-size:1rem;text-align:center;padding:8px 0;outline:none;background:transparent;margin-bottom:20px">
    <button onclick="submitScore()" style="width:100%;padding:12px;background:#111;color:white;border:none;font-family:'Roboto Mono',monospace;font-size:0.8rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;cursor:pointer;margin-bottom:8px">Submit</button>
    <button onclick="closeModal()" style="width:100%;padding:10px;background:transparent;border:1px solid #ddd;font-family:'Roboto Mono',monospace;font-size:0.7rem;cursor:pointer;color:#999">Skip</button>
  </div>
</div>


<!-- LEARN -->
<div class="page" id="page-learn">
  <div style="width:100%" id="learn-map-view">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
      <div style="font-size:0.58rem;letter-spacing:2px;text-transform:uppercase;color:#999">Levels</div>
      <button onclick="showSkipModal()" style="background:none;border:none;font-family:'Roboto Mono',monospace;font-size:0.58rem;letter-spacing:2px;text-transform:uppercase;color:#999;cursor:pointer;border-bottom:1px solid #ddd;padding-bottom:1px">Skip ahead</button>
    </div>
    <div id="learn-island-map" style="width:100%;overflow-y:scroll;max-height:72vh;padding-bottom:20px;scrollbar-width:none;-ms-overflow-style:none"></div>
  </div>

  <!-- Skip modal -->
  <div id="skip-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:100;align-items:center;justify-content:center">
    <div style="background:white;padding:28px;max-width:320px;width:90%;text-align:center">
      <div style="font-size:0.6rem;letter-spacing:3px;text-transform:uppercase;color:#999;margin-bottom:12px">Skip ahead</div>
      <div style="font-size:0.65rem;color:#888;margin-bottom:16px;line-height:1.6">Jump to a higher level to test yourself. You still need to beat it to unlock everything in between.</div>
      <input id="skip-input" type="number" min="1" max="10000" placeholder="Level number"
        style="width:100%;border:none;border-bottom:2px solid #111;font-family:'Roboto Mono',monospace;font-size:1.2rem;text-align:center;padding:8px 0;outline:none;background:transparent;margin-bottom:20px">
      <button onclick="doSkip()" style="width:100%;padding:12px;background:#111;color:white;border:none;font-family:'Roboto Mono',monospace;font-size:0.8rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;cursor:pointer;margin-bottom:8px">Go to level</button>
      <button onclick="closeSkipModal()" style="width:100%;padding:10px;background:transparent;border:1px solid #ddd;font-family:'Roboto Mono',monospace;font-size:0.7rem;cursor:pointer;color:#999">Cancel</button>
    </div>
  </div>
  <!-- Level info screen -->
  <div style="display:none;width:100%;flex-direction:column;align-items:center" id="learn-info-view">
    <div style="font-size:0.58rem;letter-spacing:2px;text-transform:uppercase;color:#999;margin-bottom:6px" id="info-level-label">Level 1</div>
    <div style="font-size:3rem;font-weight:700;letter-spacing:-2px;margin-bottom:4px" id="info-level-num">1</div>
    <div id="info-stars-prev" style="font-size:1.8rem;letter-spacing:6px;margin-bottom:24px"></div>
    <div style="width:100%;background:white;border:1px solid #ddd;padding:16px 18px;margin-bottom:8px">
      <div style="font-size:0.55rem;letter-spacing:2px;text-transform:uppercase;color:#999;margin-bottom:12px">Star targets</div>
      <div style="display:flex;justify-content:space-around;width:100%">
        <div style="text-align:center"><div style="font-size:1.1rem;font-weight:700" id="info-t1"></div><div style="font-size:0.7rem;color:#999;margin-top:2px">★</div></div>
        <div style="text-align:center"><div style="font-size:1.1rem;font-weight:700" id="info-t2"></div><div style="font-size:0.7rem;color:#999;margin-top:2px">★★</div></div>
        <div style="text-align:center"><div style="font-size:1.1rem;font-weight:700" id="info-t3"></div><div style="font-size:0.7rem;color:#999;margin-top:2px">★★★</div></div>
        <div style="text-align:center"><div style="font-size:1.1rem;font-weight:700" id="info-time"></div><div style="font-size:0.7rem;color:#999;margin-top:2px">time</div></div>
      </div>
    </div>
    <div style="width:100%;background:white;border:1px solid #ddd;padding:16px 18px;margin-bottom:24px">
      <div style="font-size:0.55rem;letter-spacing:2px;text-transform:uppercase;color:#999;margin-bottom:12px">Operations</div>
      <div id="info-ops" style="display:flex;flex-direction:column;gap:8px"></div>
    </div>
    <button class="start-btn" style="width:100%;margin-bottom:8px" onclick="beginLearnLevel()">Start level</button>
    <button class="btn-outline" style="width:100%" onclick="goToMap()">Back to levels</button>
  </div>

  <div style="display:none;width:100%;flex-direction:column;align-items:center" id="learn-game-view">
    <div style="width:100%;display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
      <div style="font-size:0.58rem;letter-spacing:2px;text-transform:uppercase;color:#999" id="learn-level-label">Level 1</div>
      <button onclick="exitLearnGame()" style="background:none;border:none;font-family:'Roboto Mono',monospace;font-size:0.58rem;letter-spacing:2px;text-transform:uppercase;color:#ccc;cursor:pointer">Exit</button>
    </div>

    <!-- Time bar: shrinks right to left -->
    <div style="width:100%;background:#f0f0eb;height:5px;border-radius:3px;margin-bottom:10px;overflow:hidden;display:flex;align-items:stretch">
      <div style="flex:1"></div>
      <div id="learn-time-bar" style="height:5px;width:100%;background:#3a9e6f;transition:width 1s linear,background 1s ease;border-radius:3px"></div>
    </div>

    <!-- Score bar with star markers below -->
    <div style="width:100%;position:relative;margin-bottom:28px">
      <!-- Track -->
      <div style="width:100%;background:#f0f0eb;height:6px;border-radius:3px;overflow:hidden">
        <div id="learn-progress-bar" style="height:100%;background:#111;border-radius:3px;transition:width 0.25s ease;width:0%"></div>
      </div>
      <!-- Star markers below bar -->
      <div id="learn-star-markers" style="position:relative;width:100%;height:48px;margin-top:4px"></div>
    </div>
    <div class="question" id="learn-question"></div>
    <input class="answer-input" id="learn-input" type="text" inputmode="numeric" autocomplete="off" spellcheck="false">
  </div>
  <div style="display:none;width:100%;text-align:center;padding:32px 0;flex-direction:column;align-items:center" id="learn-result-view">
    <div id="learn-result-stars" style="font-size:2rem;margin-bottom:12px;letter-spacing:8px"></div>
    <div style="font-size:0.6rem;letter-spacing:3px;text-transform:uppercase;color:#999;margin-bottom:8px" id="learn-result-label"></div>
    <div style="font-size:2.5rem;font-weight:700;margin-bottom:4px" id="learn-result-score"></div>
    <div style="font-size:0.65rem;color:#999;margin-bottom:28px" id="learn-result-sub"></div>
    <button class="start-btn" style="margin-bottom:8px;display:none" id="learn-next-btn" onclick="nextLearnLevel()">Next level</button>
    <button class="start-btn" style="margin-bottom:8px" onclick="retryLearnLevel()">Try again</button>
    <button class="btn-outline" style="width:100%" onclick="goToMap()">Back to levels</button>
  </div>
</div>
</body>
</html>
