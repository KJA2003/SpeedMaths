    subtraction:    { sym: '−', range: function() { return '(' + lv.addA[0] + '–' + lv.addA[1] + ') − (' + lv.addB[0] + '–' + lv.addB[1] + ')'; } },
    multiplication: { sym: '×', range: function() { return '(' + lv.mulA[0] + '–' + lv.mulA[1] + ') × (' + lv.mulB[0] + '–' + lv.mulB[1] + ')'; } },
    division:       { sym: '÷', range: function() { return '(' + lv.mulA[0] + '–' + lv.mulA[1] + ') ÷ (' + lv.mulB[0] + '–' + lv.mulB[1] + ')'; } }
