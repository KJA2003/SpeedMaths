function startPatternPractice(p) {
  // Build exactly 20 questions: exact misses first, then generated similar
  var queue = [], seen = new Set();

  // Add the exact wrong questions first
  p.items.forEach(function(item) {
    if (!seen.has(item.question)) {
      queue.push({ question:item.question, answer:item.answer, op:item.op, a:item.a, b:item.b, tag:'Exact miss', similar:false });
      seen.add(item.question);
    }
  });

  // Fill up to 20 with generated questions following the pattern
  var attempts = 0;
  while (queue.length < 20 && attempts < 200) {
    attempts++;
    try {
      var sim = p.generateSimilar();
      if (sim && !seen.has(sim.question)) {
        queue.push(sim);
        seen.add(sim.question);
      }
    } catch(e) { break; }
  }

  // Shuffle and cap at 20
  queue = queue.sort(function() { return Math.random() - 0.5; }).slice(0, 20);

  _runPractice(queue.map(function(q) {
    return Object.assign({}, q, { _cleared:false, _failed:false, _seen:false });
  }));
}

function startPracticeSession() {
  // "Start practice" button — drills all patterns, 20 questions total
  if (!_cachedPatterns.length) return;
  var queue = [], seen = new Set();

  // One pass: exact misses from all patterns
  _cachedPatterns.forEach(function(p) {
    p.items.forEach(function(item) {
      if (!seen.has(item.question)) {
        queue.push({ question:item.question, answer:item.answer, op:item.op, a:item.a, b:item.b, tag:'Exact miss', similar:false });
        seen.add(item.question);
      }
    });
  });

  // Fill up to 20 with generated questions from random patterns
  var attempts = 0;
  while (queue.length < 20 && attempts < 300) {
    attempts++;
    var p = _cachedPatterns[Math.floor(Math.random() * _cachedPatterns.length)];
    try {
      var sim = p.generateSimilar();
      if (sim && !seen.has(sim.question)) { queue.push(sim); seen.add(sim.question); }
    } catch(e) {}
  }

  queue = queue.sort(function() { return Math.random() - 0.5; }).slice(0, 20);
  _runPractice(queue.map(function(q) {
    return Object.assign({}, q, { _cleared:false, _failed:false, _seen:false });
  }));
}


