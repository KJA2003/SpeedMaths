// ================================================================
// PATTERN DETECTION
// For division: question = "(a*b) / a = b", so a=divisor, b=answer.
// shared_a (same divisor) title: "? / 3 = ?"   generated: vary b, keep a fixed
// shared_b (same answer)  title: "? / ? = 3"   generated: vary a, keep b fixed
// ================================================================
function buildPatterns(trouble, games) {
  games = games || [];

  // Get configured range [min, max] for op+slot from the most recent game that used it
  function getRange(op, slot) {
    for (var i = games.length - 1; i >= 0; i--) {
      var g = games[i];
      if (!g.ranges || !g.ops || g.ops.indexOf(op) === -1) continue;
      if (op === 'multiplication' || op === 'division') {
        return slot === 'a' ? g.ranges.mulA : g.ranges.mulB;
      } else {
        return slot === 'a' ? g.ranges.addA : g.ranges.addB;
      }
    }
    return null;
  }

  // Filter A: trivial if range is <=2 values wide, or this value covers >40% of the range
  function isBoring(op, slot, val) {
    var r = getRange(op, slot);
    if (!r) return false;
    var width = r[1] - r[0];
    if (width <= 1) return true;
    return (1 / (width + 1)) > 0.40;
  }

function buildPatterns_inner(trouble) {
  var entries = Object.values(trouble);
  if (!entries.length) return [];
  var patterns = [];
  var opList = ['addition','subtraction','multiplication','division'];

  // Helper: build a single question object without going through generateQuestion
  // (which uses config ranges). Instead we build it directly.
  function makeQ(op, a, b) {
    var q, ans;
    if (op === 'addition')       { q = a + ' + ' + b + ' ='; ans = a + b; }
    else if (op === 'subtraction'){ var big=Math.max(a,b), sml=Math.min(a,b); q = big + ' - ' + sml + ' ='; ans = big-sml; a=big; b=sml; }
    else if (op === 'multiplication'){ q = a + ' x ' + b + ' ='; ans = a*b; }
    else /* division */          { q = (a*b) + ' \u00f7 ' + a + ' ='; ans = b; }
    return { question:q, answer:ans, op:op, a:a, b:b };
  }

  function safeA(op, a) { return Math.max(2, a); }
  function safeB(op, b) { return Math.max(2, b); }

  // 1. Shared exact operand (multiplication and division only)
  opList.forEach(function(op) {
    if (op === 'addition' || op === 'subtraction') return;
    var opEntries = entries.filter(function(e) { return e.op === op; });
    if (opEntries.length < 2) return;
    var sym = opSymbols[op];

    // Group by a
    var byA = {};
    opEntries.forEach(function(e) { if (!byA[e.a]) byA[e.a] = []; byA[e.a].push(e); });
    Object.keys(byA).forEach(function(aVal) {
      var items = byA[aVal]; if (items.length < 2) return;
      var av = parseInt(aVal);
      if (isBoring(op, 'a', av)) return;
      // For division: question is "(a*b) / a = b", fixed a means fixed divisor: "? / 3 = ?"
      var tpl = op === 'division' ? '? \u00f7 ' + av + ' = ?' : av + ' ' + sym + ' ? =';
      var ttl = op === 'division'
        ? 'Division: struggle dividing by ' + av
        : opName(op) + ': struggle with ' + av + ' ' + sym + ' ?';
      patterns.push({
        id: 'shared_a_' + op + '_' + aVal,
        title: ttl,
        template: tpl,
        detail: op === 'division' ? 'Questions where you divide by ' + av + '.' : 'Questions involving ' + av + ' ' + sym + ' ?',
        examples: items.slice(0,4).map(function(i) { return i.question; }),
        count: items.reduce(function(s,i) { return s+i.count; }, 0),
        items: items,
        generateSimilar: (function(capturedOp, capturedA, capturedItems) {
          return function() {
            var bVals = capturedItems.map(function(i) { return i.b; });
            var bMin = Math.max(2, Math.min.apply(null,bVals) - 4);
            var bMax = Math.max.apply(null,bVals) + 4;
            var newB = safeB(capturedOp, randInt(bMin, bMax));
            var q = makeQ(capturedOp, capturedA, newB);
            q.tag = tpl; q.similar = true; return q;
          };
        })(op, av, items)
      });
    });

    // Group by b
    var byB = {};
    opEntries.forEach(function(e) { if (!byB[e.b]) byB[e.b] = []; byB[e.b].push(e); });
    Object.keys(byB).forEach(function(bVal) {
      var items = byB[bVal]; if (items.length < 2) return;
      var bv = parseInt(bVal);
      if (isBoring(op, 'b', bv)) return;
      // For division: fixed b means fixed answer: "? / ? = 3"
      var tpl2 = op === 'division' ? '? \u00f7 ? = ' + bv : '? ' + sym + ' ' + bv + ' =';
      var ttl2 = op === 'division'
        ? 'Division: answer ' + bv + ' keeps tripping you up'
        : opName(op) + ': struggle with ? ' + sym + ' ' + bv + ' =';
      patterns.push({
        id: 'shared_b_' + op + '_' + bVal,
        title: ttl2,
        template: tpl2,
        detail: op === 'division' ? 'Questions where the answer is ' + bv + '.' : 'Questions involving ? ' + sym + ' ' + bv + '.',
        examples: items.slice(0,4).map(function(i) { return i.question; }),
        count: items.reduce(function(s,i) { return s+i.count; }, 0),
        items: items,
        generateSimilar: (function(capturedOp, capturedB, capturedItems) {
          return function() {
            var aVals = capturedItems.map(function(i) { return i.a; });
            var aMin = Math.max(2, Math.min.apply(null,aVals) - 4);
            var aMax = Math.max.apply(null,aVals) + 4;
            var newA = safeA(capturedOp, randInt(aMin, aMax));
            var q = makeQ(capturedOp, newA, capturedB);
            q.tag = tpl2; q.similar = true; return q;
          };
        })(op, bv, items)
      });
    });
  });

  // 2. Shared units digit (multiplication only — add/sub units patterns aren't useful)
  ['multiplication'].forEach(function(op) {
    var opEntries = entries.filter(function(e) { return e.op === op; });
    if (opEntries.length < 3) return;
    var sym = opSymbols[op];
    var byUnitsB = {};
    opEntries.forEach(function(e) { var u = e.b % 10; if (!byUnitsB[u]) byUnitsB[u] = []; byUnitsB[u].push(e); });
    Object.keys(byUnitsB).forEach(function(u) {
      var items = byUnitsB[u]; if (items.length < 2) return;
      var ui = parseInt(u);
      var tpl3 = '? x ?' + ui + ' =';
      patterns.push({
        id: 'units_b_' + op + '_' + u,
        title: 'Multiplication: struggle with numbers ending in ' + ui,
        template: tpl3,
        detail: 'Questions where the second number ends in ' + ui + '.',
        examples: items.slice(0,4).map(function(i) { return i.question; }),
        count: items.reduce(function(s,i) { return s+i.count; }, 0),
        items: items,
        generateSimilar: (function(capturedItems, capturedU) {
          return function() {
            var ref = capturedItems[Math.floor(Math.random()*capturedItems.length)];
            // Keep units digit, vary tens part
            var tensPart = Math.max(0, Math.floor(ref.b / 10) + randInt(-2, 2)) * 10;
            var newB = Math.max(capturedU === 0 ? 10 : capturedU, tensPart + capturedU);
            var newA = Math.max(2, ref.a + randInt(-2, 2));
            var q = makeQ('multiplication', newA, newB);
            q.tag = '? x ?' + capturedU; q.similar = true; return q;
          };
        })(items, ui)
      });
    });
  });

  // 3. Number range clusters (multiplication only)
  ['multiplication'].forEach(function(op) {
    var opEntries = entries.filter(function(e) { return e.op === op; });
    if (opEntries.length < 3) return;
    var sym = opSymbols[op];
    var buckets = {};
    opEntries.forEach(function(e) { var bucket = Math.floor(e.b/10)*10; if (!buckets[bucket]) buckets[bucket] = []; buckets[bucket].push(e); });
    Object.keys(buckets).forEach(function(lo) {
      var items = buckets[lo]; if (items.length < 2) return;
      var loI = parseInt(lo), hiI = loI + 9;
      var tpl4 = '? x ' + loI + '-' + hiI + ' =';
      patterns.push({
        id: 'range_' + op + '_' + lo,
        title: 'Multiplication: numbers in the ' + loI + '-' + hiI + ' range',
        template: tpl4,
        detail: 'Questions with second number between ' + loI + ' and ' + hiI + '.',
        examples: items.slice(0,4).map(function(i) { return i.question; }),
        count: items.reduce(function(s,i) { return s+i.count; }, 0),
        items: items,
        generateSimilar: (function(capturedItems, capturedLo, capturedHi) {
          return function() {
            var ref = capturedItems[Math.floor(Math.random()*capturedItems.length)];
            var newB = randInt(capturedLo, capturedHi);
            var newA = Math.max(2, ref.a + randInt(-2, 2));
            var q = makeQ('multiplication', newA, newB);
            q.tag = capturedLo + '-' + capturedHi; q.similar = true; return q;
          };
        })(items, loI, hiI)
      });
    });
  });

  // 4. Repeatedly missed
  var repeated = entries.filter(function(e) { return e.count >= 2; });
  if (repeated.length >= 1) {
    patterns.push({
      id: 'repeated',
      title: 'Repeatedly missed',
      template: '(same questions across multiple games)',
      detail: 'Questions you\'ve got wrong across multiple games.',
      examples: repeated.slice(0,4).map(function(i) { return i.question; }),
      count: repeated.reduce(function(s,i) { return s+i.count; }, 0),
      items: repeated,
      generateSimilar: (function(capturedRepeated) {
        return function() {
          var ref = capturedRepeated[Math.floor(Math.random()*capturedRepeated.length)];
          return { question:ref.question, answer:ref.answer, op:ref.op, a:ref.a, b:ref.b, tag:'Repeated miss', similar:false };
        };
      })(repeated)
    });
  }

  // Scoring and redundancy pruning — max 6 patterns
  function specificityBonus(id) {
    if (id === 'repeated')             return 4;
    if (id.indexOf('shared_') === 0)   return 3;
    if (id.indexOf('units_') === 0)    return 2;
    if (id.indexOf('range_') === 0)    return 2;
    return 1;
  }
  var seenIds = new Set();
  var unique = patterns.filter(function(p) {
    if (seenIds.has(p.id)) return false;
    seenIds.add(p.id); return true;
  });
  unique.forEach(function(p) { p._score = p.count * specificityBonus(p.id); });
  unique.sort(function(a,b) { return b._score - a._score; });

  var selected = [], covered = new Set();
  for (var i = 0; i < unique.length; i++) {
    if (selected.length >= 6) break;
    var p = unique[i];
    var pQs = p.items.map(function(it) { return it.question; });
    var overlap = pQs.filter(function(q) { return covered.has(q); }).length;
    if (pQs.length > 0 && overlap / pQs.length > 0.75) continue;
    selected.push(p);
    pQs.forEach(function(q) { covered.add(q); });
  }
  return selected;
} // end buildPatterns_inner
  return buildPatterns_inner(trouble);
} // end buildPatterns

