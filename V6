  var positions = ['15%', '50%', '85%', '50%']; // 4-step zigzag cycle

  var mapEl = document.createElement('div');
  mapEl.style.cssText = 'position:relative;width:100%;';

  // We'll render as stacked rows, each 80px tall
  var rowH = 96;
  var totalH = levels.length * rowH + 40;
  mapEl.style.height = totalH + 'px';

  levels.forEach(function(n, rowIdx) {
    var lv = getLevel(n);
    var stars = ld.stars[n] || 0;
    var locked = n > unlocked;
    var isCurrent = n === unlocked;

    // Position: zigzag
    var posIdx = (n - 1) % positions.length;
    var leftPct = positions[posIdx];
    var topPx = rowIdx * rowH + 20;

    // Draw path line to next level (lower = higher index in our array)
    if (rowIdx < levels.length - 1) {
      var nextN = levels[rowIdx + 1];
      var nextPosIdx = (nextN - 1) % positions.length;
      var nextLeftPct = positions[nextPosIdx];

      var line = document.createElement('div');
      // Simple connector: a dotted vertical-ish line
      var x1 = parseFloat(leftPct);
      var x2 = parseFloat(nextLeftPct);
      var midX = (x1 + x2) / 2;
      line.style.cssText = 'position:absolute;top:' + (topPx + 36) + 'px;left:' + leftPct + ';width:2px;height:' + (rowH - 36) + 'px;background:' + (locked ? '#e8e8e3' : '#ddd') + ';transform:translateX(-50%);';
      if (x1 !== x2) {
        // Diagonal: use a rotated element
        var angle = Math.atan2(rowH - 36, (x2 - x1) / 100 * 480) * 180 / Math.PI; // approx
        line.style.cssText = 'position:absolute;top:' + (topPx + 32) + 'px;left:' + Math.min(x1,x2) + '%;width:' + Math.abs(x2-x1) + '%;height:2px;background:' + (locked ? '#e8e8e3' : '#ddd') + ';';
      }
      mapEl.appendChild(line);
    }

    // Island circle
    var island = document.createElement('div');
    var size = isCurrent ? 64 : 56;
    var bg = locked ? '#f0f0eb' : isCurrent ? '#111' : '#fff';
    var border = locked ? '2px solid #e0e0da' : isCurrent ? '2px solid #111' : '2px solid #111';
    island.style.cssText = 'position:absolute;top:' + topPx + 'px;left:' + leftPct + ';width:' + size + 'px;height:' + size + 'px;border-radius:50%;background:' + bg + ';border:' + border + ';transform:translateX(-50%);display:flex;align-items:center;justify-content:center;cursor:' + (locked ? 'default' : 'pointer') + ';flex-direction:column;';

    var numEl = document.createElement('div');
    numEl.style.cssText = 'font-family:"Roboto Mono",monospace;font-size:' + (isCurrent ? '0.75' : '0.65') + 'rem;font-weight:700;color:' + (locked ? '#bbb' : isCurrent ? '#fff' : '#111') + ';line-height:1;';
    numEl.textContent = n;
    island.appendChild(numEl);

    // Stars curved around top arc of island
    var cx = parseFloat(leftPct); // centre x in percent — we'll use px offsets
    var r = size / 2 + 13; // radius from centre of island to star centre
    // Three stars at -40deg, 0deg, +40deg from top (270deg = straight up)
    var starAngles = [-28, 0, 28];
    for (var si = 0; si < 3; si++) {
      var angleRad = (270 + starAngles[si]) * Math.PI / 180;
      var sx = Math.cos(angleRad) * r; // offset from island centre in px
      var sy = Math.sin(angleRad) * r;
      var islandCentreX_approx = 0; // relative to island centre
      var islandCentreY_approx = 0;
      var starDiv = document.createElement('div');
      var earned = !locked && si < stars;
      var shown  = !locked; // always show outline even if not earned
      starDiv.style.cssText = 'position:absolute;' +
        'left:' + leftPct + ';' +
        'top:' + (topPx + size/2 + sy) + 'px;' +
        'transform:translate(calc(-50% + ' + sx + 'px), -50%);' +
        'font-size:1.6rem;line-height:1;' +
        'color:' + (earned ? '#111' : (locked ? 'transparent' : '#ddd')) + ';' +
        'pointer-events:none;';
      starDiv.textContent = earned ? '★' : '☆';
      if (shown || locked) mapEl.appendChild(starDiv);
    }
    if (locked) {
      var lockDiv = document.createElement('div');
      lockDiv.style.cssText = 'position:absolute;top:' + (topPx + size/2 - 12) + 'px;left:' + leftPct + ';transform:translateX(-50%);font-size:0.8rem;pointer-events:none;';
      lockDiv.textContent = '🔒';
      mapEl.appendChild(lockDiv);
    }

    if (!locked) {
      (function(lvNum) {
        island.addEventListener('click', function() { showLearnInfo(lvNum); });
      })(n);
    }

    mapEl.appendChild(island);

    // Level description beside island
    var label = document.createElement('div');
    var labelLeft = parseFloat(leftPct) > 50 ? (parseFloat(leftPct) - 38) + '%' : (parseFloat(leftPct) + 32) + '%';
    var textAlign = parseFloat(leftPct) > 50 ? 'right' : 'left';
    label.style.cssText = 'position:absolute;top:' + (topPx + 8) + 'px;left:' + labelLeft + ';font-size:0.52rem;color:' + (locked ? '#ccc' : '#888') + ';max-width:90px;line-height:1.4;text-align:' + textAlign + ';font-family:"Roboto Mono",monospace;';
    label.textContent = lv.desc;
    mapEl.appendChild(label);
  });

  container.appendChild(mapEl);

  // Scroll to current level
  var currentY = levels.indexOf(unlocked) * rowH;
  // Scroll to current level
  var currentIdx = levels.indexOf(unlocked);
  var scrollTarget = currentIdx * rowH;
  setTimeout(function() { container.scrollTop = Math.max(0, scrollTarget - 150); }, 50);
}

