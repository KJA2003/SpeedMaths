function drawGraph(canvasId, games, getValue, color) {
  var canvas = document.getElementById(canvasId);
  var dpr = window.devicePixelRatio || 1;
  var W = canvas.parentElement.clientWidth - 32 || 400, H = 120;
  canvas.width = W * dpr; canvas.height = H * dpr;
  canvas.style.width = W + 'px'; canvas.style.height = H + 'px';
  var ctx = canvas.getContext('2d'); ctx.scale(dpr, dpr); ctx.clearRect(0,0,W,H);
  var vals = games.map(getValue);
  if (!vals.length) return;
  if (vals.length < 2) {
    ctx.fillStyle = '#ddd'; ctx.fillRect(0, H/2-1, W, 2);
    ctx.beginPath(); ctx.arc(W/2, H/2, 4, 0, Math.PI*2); ctx.fillStyle = color; ctx.fill(); return;
  }
  var minV = Math.min.apply(null, vals) * 0.9;
  var maxV = Math.max.apply(null, vals) * 1.1 || 1;
  var pad = { t:16, b:8, l:36, r:8 };
  var gW = W - pad.l - pad.r, gH = H - pad.t - pad.b;
  function px(i) { return pad.l + (i / (vals.length - 1)) * gW; }
  function py(v) { return pad.t + gH - ((v - minV) / (maxV - minV)) * gH; }
  ctx.strokeStyle = '#eee'; ctx.lineWidth = 1;
  [0, 0.5, 1].forEach(function(t) { var y = pad.t + gH * (1-t); ctx.beginPath(); ctx.moveTo(pad.l, y); ctx.lineTo(pad.l+gW, y); ctx.stroke(); });
  ctx.beginPath();
  vals.forEach(function(v, i) { if (i === 0) ctx.moveTo(px(i), py(v)); else ctx.lineTo(px(i), py(v)); });
  ctx.strokeStyle = color; ctx.lineWidth = 2; ctx.lineJoin = 'round'; ctx.stroke();
  ctx.beginPath();
  vals.forEach(function(v, i) { if (i === 0) ctx.moveTo(px(i), py(v)); else ctx.lineTo(px(i), py(v)); });
  ctx.lineTo(px(vals.length-1), pad.t+gH); ctx.lineTo(px(0), pad.t+gH); ctx.closePath();
  ctx.fillStyle = color + '18'; ctx.fill();
  vals.forEach(function(v, i) { ctx.beginPath(); ctx.arc(px(i), py(v), 3, 0, Math.PI*2); ctx.fillStyle = color; ctx.fill(); });
  ctx.fillStyle = '#bbb'; ctx.font = '9px Roboto Mono, monospace'; ctx.textAlign = 'right';
  ctx.fillText(maxV.toFixed(maxV < 10 ? 1 : 0), pad.l - 4, pad.t + 5);
  ctx.fillText(minV.toFixed(minV < 10 ? 1 : 0), pad.l - 4, pad.t + gH + 1);
}

