function loadPlayLeaderboard() {
  var list = document.getElementById('play-lb-list');
  var loading = document.getElementById('play-lb-loading');
  if (!list) return;
  list.innerHTML = '';
  loading.style.display = 'block';
  loading.textContent = 'Loading...';

  fetch(SUPA_URL + '/rest/v1/rpc/get_best_scores', {
    method: 'POST',
    headers: { 'apikey': SUPA_KEY, 'Authorization': 'Bearer ' + SUPA_KEY, 'Content-Type': 'application/json', 'Accept': 'application/json' },
    body: JSON.stringify({ dur: _playLbDur, win_start: null })
  })
  .then(function(r) { return r.json(); })
  .then(function(rows) {
    loading.style.display = 'none';
    if (!Array.isArray(rows) || !rows.length) {
      loading.style.display = 'block';
      loading.textContent = 'No scores yet.';
      return;
    }
    rows = rows.sort(function(a,b) { return b.score - a.score; }).slice(0, 5);
    var myName = localStorage.getItem('arith_name') || '';
    rows.forEach(function(row, i) {
      var el = document.createElement('div');
      el.className = 'lb-row';
      var isYou = myName && row.name.toLowerCase() === myName.toLowerCase();
      el.innerHTML =
        '<div class="lb-rank' + (i < 3 ? ' top3' : '') + '">' + (i+1) + '</div>' +
        '<div class="lb-name' + (isYou ? ' you' : '') + '">' + escHtml(row.name) + '</div>' +
        '<div class="lb-score">' + row.score + '</div>';
      list.appendChild(el);
    });
  })
  .catch(function() {
    loading.style.display = 'block';
    loading.textContent = 'Could not load scores.';
  });
}



