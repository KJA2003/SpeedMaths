<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Alkaliner</title>
<link href="https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  background: #f5f5f0; color: #111; font-family: 'Roboto Mono', monospace;
  min-height: 100vh; display: flex; flex-direction: column; align-items: center; padding: 0 0 60px;
}

/* NAV */
.nav {
  width: 100%; max-width: 520px; display: flex; border-bottom: 1px solid #ddd;
  margin-bottom: 36px; background: #f5f5f0; position: sticky; top: 0; z-index: 10;
}
.nav-btn {
  flex: 1; padding: 16px 4px; background: none; border: none;
  font-family: 'Roboto Mono', monospace; font-size: 0.55rem; letter-spacing: 1.5px;
  text-transform: uppercase; color: #aaa; cursor: pointer;
  border-bottom: 2px solid transparent; margin-bottom: -1px;
}
.nav-btn.active { color: #111; border-bottom-color: #111; }
.nav-btn.nav-locked { opacity: 0.3; cursor: default; pointer-events: none; }

/* PAGES */
.page { display: none; flex-direction: column; align-items: center; width: 100%; max-width: 520px; padding: 0 20px; }
.page.active { display: flex; }
.section-label { font-size: 0.58rem; letter-spacing: 2px; text-transform: uppercase; color: #999; margin-bottom: 8px; width: 100%; }

/* CONFIG */
.ops-list { display: flex; flex-direction: column; gap: 2px; margin-bottom: 24px; width: 100%; }
.op-row { display: flex; align-items: center; gap: 12px; padding: 10px 14px; background: white; border: 1px solid #ddd; cursor: pointer; user-select: none; }
.op-row.active { border-color: #111; }
.op-check { width: 13px; height: 13px; border: 1px solid #ccc; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 8px; }
.op-row.active .op-check { background: #111; border-color: #111; color: white; }
.op-label { font-size: 0.75rem; font-weight: 700; min-width: 110px; }
.range-inline { font-size: 0.62rem; color: #999; display: flex; align-items: center; gap: 4px; flex-wrap: wrap; }
.range-inline input {
  width: 36px; border: none; border-bottom: 1px solid #ccc; background: transparent;
  font-family: 'Roboto Mono', monospace; font-size: 0.62rem; text-align: center;
  color: #111; padding: 1px 0; outline: none;
}
.range-inline input:focus { border-bottom-color: #111; }
.duration-row { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 24px; width: 100%; }
.dur-btn {
  padding: 7px 14px; background: white; border: 1px solid #ddd;
  font-family: 'Roboto Mono', monospace; font-size: 0.7rem; cursor: pointer; color: #999;
}
.dur-btn.active { border-color: #111; color: #111; font-weight: 700; }
.start-btn {
  width: 100%; padding: 13px; background: #111; color: white; border: none;
  font-family: 'Roboto Mono', monospace; font-size: 0.8rem; font-weight: 700;
  letter-spacing: 2px; text-transform: uppercase; cursor: pointer;
}
.start-btn:hover { background: #333; }

/* pace toggle in config */
.toggle-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 10px 14px; background: white; border: 1px solid #ddd; margin-bottom: 24px; width: 100%; cursor: pointer;
}
.toggle-row-label { font-size: 0.75rem; font-weight: 700; }
.toggle-row-sub { font-size: 0.6rem; color: #999; margin-top: 2px; }
.toggle-switch { position: relative; width: 36px; height: 20px; flex-shrink: 0; }
.toggle-switch input { opacity: 0; width: 0; height: 0; position: absolute; }
.toggle-slider { position: absolute; inset: 0; background: #ddd; border-radius: 20px; transition: background 0.2s; }
.toggle-slider::before { content: ''; position: absolute; width: 14px; height: 14px; left: 3px; top: 3px; background: white; border-radius: 50%; transition: transform 0.2s; }
.toggle-switch input:checked + .toggle-slider { background: #111; }
.toggle-switch input:checked + .toggle-slider::before { transform: translateX(16px); }

/* GAME */
.timer-bar-wrap { width: 100%; height: 3px; background: #ddd; margin-bottom: 32px; }
.timer-bar { height: 100%; background: #111; transition: width 1s linear; }
.hud { display: flex; justify-content: space-between; width: 100%; margin-bottom: 48px; font-size: 0.6rem; letter-spacing: 1px; color: #999; text-transform: uppercase; }
.hud-val { font-size: 1.1rem; color: #111; font-weight: 700; margin-top: 4px; }
.question { font-size: 3.2rem; font-weight: 700; letter-spacing: -1px; margin-bottom: 20px; text-align: center; white-space: nowrap; line-height: 1; }
.answer-input {
  background: transparent; border: none; border-bottom: 2px solid #111;
  font-family: 'Roboto Mono', monospace; font-size: 2.8rem; font-weight: 700;
  text-align: center; width: 200px; outline: none; color: #111; padding: 4px 0; caret-color: #111;
}
.stop-btn {
  margin-top: 32px; background: none; border: none; font-family: 'Roboto Mono', monospace;
  font-size: 0.58rem; letter-spacing: 2px; text-transform: uppercase;
  color: #ccc; cursor: pointer; padding: 4px 0;
}
.stop-btn:hover { color: #999; }

/* PACE BAR */
.pace-wrap { width: 100%; margin-top: 24px; display: flex; flex-direction: column; align-items: center; gap: 6px; min-height: 44px; }
.pace-wrap.hidden { display: none; }
.pace-label { font-size: 0.58rem; letter-spacing: 2px; text-transform: uppercase; color: #bbb; }
.pace-bar-wrap { width: 100%; position: relative; height: 6px; background: #e8e8e3; overflow: hidden; }
.pace-bar-wrap::after { content: ''; position: absolute; left: 50%; top: -3px; width: 1px; height: 12px; background: #ccc; }
.pace-fill { position: absolute; top: 0; height: 100%; transition: width 0.15s ease-out, background 0.3s ease; }
.pace-fill.behind { left: 50%; background: #e05a3a; }
.pace-fill.ahead { right: 50%; background: #3a9e6f; }
.pace-number { font-size: 0.68rem; font-weight: 700; letter-spacing: 1px; color: #999; min-height: 1em; transition: color 0.3s ease; }
.pace-number.behind { color: #e05a3a; }
.pace-number.ahead { color: #3a9e6f; }
.pace-number.no-avg { color: #bbb; font-weight: 400; }

/* RESULTS */
.result-label { font-size: 0.6rem; letter-spacing: 3px; text-transform: uppercase; color: #999; margin-bottom: 6px; }
.result-score { font-size: clamp(4rem,16vw,7rem); font-weight: 700; line-height: 1; letter-spacing: -4px; margin-bottom: 4px; }
.result-sub { font-size: 0.7rem; color: #999; margin-bottom: 24px; }
.stats { display: flex; gap: 2px; width: 100%; margin-bottom: 24px; }
.stat { flex: 1; background: white; border: 1px solid #ddd; padding: 14px 8px; text-align: center; }
.stat-val { font-size: 1.3rem; font-weight: 700; }
.stat-key { font-size: 0.55rem; letter-spacing: 1px; text-transform: uppercase; color: #999; margin-top: 4px; }
.chart-wrap { width: 100%; background: white; border: 1px solid #ddd; padding: 18px 18px 14px; margin-bottom: 14px; text-align: left; }
.chart-title { font-size: 0.58rem; letter-spacing: 2px; text-transform: uppercase; color: #999; margin-bottom: 16px; }
.chart-rows { display: flex; flex-direction: column; gap: 12px; }
.chart-row { display: flex; align-items: center; gap: 10px; }
.chart-op-label { font-size: 1rem; font-weight: 700; width: 26px; text-align: center; flex-shrink: 0; }
.bar-track { flex: 1; height: 18px; background: #f0f0eb; position: relative; overflow: hidden; }
.bar-fill { height: 100%; background: #111; width: 0%; transition: width 0.7s cubic-bezier(0.16,1,0.3,1); }
.bar-fill.slowest { background: #bbb; }
.chart-time-label { font-size: 0.62rem; font-weight: 700; width: 46px; text-align: right; flex-shrink: 0; color: #555; }
.chart-count { font-size: 0.56rem; color: #bbb; width: 34px; text-align: right; flex-shrink: 0; }
.chart-no-data { font-size: 0.62rem; color: #bbb; text-align: center; padding: 10px 0; }
.btn-row { display: flex; gap: 8px; width: 100%; }
.btn-outline {
  flex: 1; padding: 12px 8px; background: transparent; border: 1px solid #111;
  font-family: 'Roboto Mono', monospace; font-size: 0.65rem; font-weight: 700;
  letter-spacing: 1px; text-transform: uppercase; cursor: pointer; line-height: 1.3;
}
.btn-outline:hover { background: #111; color: white; }
.btn-outline:disabled { opacity: 0.25; cursor: not-allowed; border-color: #999; color: #999; }
.btn-outline:disabled:hover { background: transparent; color: #999; }

/* HISTORY */
.history-controls { display: flex; gap: 4px; margin-bottom: 20px; width: 100%; }
.hist-btn { padding: 6px 12px; background: white; border: 1px solid #ddd; font-family: 'Roboto Mono', monospace; font-size: 0.62rem; cursor: pointer; color: #999; }
.hist-btn.active { border-color: #111; color: #111; font-weight: 700; }
.graph-wrap { width: 100%; background: white; border: 1px solid #ddd; padding: 16px; margin-bottom: 16px; }
.graph-title { font-size: 0.58rem; letter-spacing: 2px; text-transform: uppercase; color: #999; margin-bottom: 12px; }
canvas { width: 100%; display: block; }
.history-table { width: 100%; border-collapse: collapse; font-size: 0.62rem; margin-bottom: 20px; }
.history-table th { text-align: left; font-size: 0.55rem; letter-spacing: 1px; text-transform: uppercase; color: #999; padding: 6px 8px; border-bottom: 1px solid #ddd; }
.history-table td { padding: 8px 8px; border-bottom: 1px solid #f0f0eb; }
.history-table tr:last-child td { border-bottom: none; }
.no-history { font-size: 0.65rem; color: #bbb; text-align: center; padding: 32px 0; width: 100%; }

/* PATTERNS */
.pattern-card { width: 100%; background: white; border: 1px solid #ddd; padding: 16px; margin-bottom: 8px; }
.pattern-card-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; gap: 8px; }
.pattern-card-title { font-size: 0.75rem; font-weight: 700; }
.pattern-card-count { font-size: 0.6rem; color: #999; flex-shrink: 0; }
.pattern-bar-wrap { display: none; }
.pattern-bar-fill { display: none; }
.pattern-card-detail { font-size: 0.6rem; color: #888; line-height: 1.7; }
.pattern-examples { margin-top: 8px; display: flex; flex-wrap: wrap; gap: 4px; }
.pattern-ex-chip { font-size: 0.58rem; padding: 3px 7px; background: #f5f5f0; border: 1px solid #e0e0da; color: #555; }
.pattern-template { margin-top: 8px; font-size: 0.68rem; font-weight: 700; color: #111; letter-spacing: -0.5px; }
.pattern-practice-btn {
  margin-top: 12px; padding: 7px 14px; background: transparent; border: 1px solid #111;
  font-family: 'Roboto Mono', monospace; font-size: 0.62rem; font-weight: 700;
  letter-spacing: 1px; text-transform: uppercase; cursor: pointer; width: 100%;
}
.pattern-practice-btn:hover { background: #111; color: white; }
.no-patterns { font-size: 0.65rem; color: #bbb; text-align: center; padding: 32px 0; width: 100%; }

/* PRACTICE */
.practice-meta { display: flex; justify-content: space-between; width: 100%; margin-bottom: 48px; font-size: 0.6rem; letter-spacing: 1px; color: #999; text-transform: uppercase; }
.practice-meta-val { font-size: 1rem; color: #111; font-weight: 700; margin-top: 4px; }
.practice-tag { display: inline-block; font-size: 0.55rem; letter-spacing: 2px; text-transform: uppercase; padding: 3px 8px; border: 1px solid #ddd; color: #aaa; margin-bottom: 16px; margin-right: 4px; }
.practice-tag.tag-exact { border-color: #111; color: #111; }
.practice-tag.tag-similar { border-color: #888; color: #666; }

/* LEADERBOARD */
.lb-row { display:flex; align-items:center; gap:12px; padding:10px 14px; background:white; border:1px solid #ddd; font-size:0.7rem; }
.lb-rank { font-size:0.6rem; color:#bbb; width:20px; flex-shrink:0; text-align:right; }
.lb-rank.top3 { color:#111; font-weight:700; }
.lb-name { flex:1; font-weight:700; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.lb-name.you { color:#3a9e6f; }
.lb-score { font-size:1rem; font-weight:700; flex-shrink:0; }
.lb-date { font-size:0.55rem; color:#bbb; flex-shrink:0; }
#learn-island-map::-webkit-scrollbar { display: none; }
</style>
<script>
document.addEventListener("DOMContentLoaded", function() {
(function() {
// ================================================================
// STORAGE
// ================================================================
function loadData() {
  try { return JSON.parse(localStorage.getItem('arith_v3') || 'null') || { games: [], trouble: {} }; }
  catch(e) { return { games: [], trouble: {} }; }
}
function saveData(d) {
  try { localStorage.setItem('arith_v3', JSON.stringify(d)); } catch(e) {}
}

// ================================================================
// NAV
// ================================================================
document.querySelectorAll('.nav-btn').forEach(function(btn) {
  btn.addEventListener('click', function() { showPage(btn.dataset.page); });
});

function showPage(name) {
  document.querySelectorAll('.page').forEach(function(p) { p.classList.remove('active'); });
  document.querySelectorAll('.nav-btn').forEach(function(b) { b.classList.remove('active'); });
  document.getElementById('page-' + name).classList.add('active');
  document.querySelector('.nav-btn[data-page="' + name + '"]').classList.add('active');
  if (name === 'history') renderHistory();
  if (name === 'practice') { renderPatterns(); renderPracticeConfig(); }
  if (name === 'leaderboard') loadLeaderboard();
  if (name === 'play') { loadPlayLeaderboard(); updateFirstTimeState(); }
  if (name === 'learn') { renderLearnMap(); }
}

// ================================================================
// GAME STATE
// ================================================================
var selectedOps = new Set(['addition','subtraction','multiplication','division']);
var duration = 120;
var score = 0, troubleCount = 0;
var currentAnswer = null, currentOp = null, currentQuestion = null;
var currentQA = null, currentQB = null;
var questionStartTime = null;
var timerInterval = null;
var timeLeft = 0, accepting = false, currentQuestionHadTrouble = false;
var answeredQuestions = [];

var opData = {
  addition:       { total: 0, count: 0 },
  subtraction:    { total: 0, count: 0 },
  multiplication: { total: 0, count: 0 },
  division:       { total: 0, count: 0 }
};
var opSymbols = { addition: '+', subtraction: '-', multiplication: 'x', division: '÷' };

// ================================================================
// HELPERS
// ================================================================
function stopProp(e) { e.stopPropagation(); }
function randInt(a, b) {
  a = parseInt(a); b = parseInt(b);
  if (a > b) { var t = a; a = b; b = t; }
  return Math.floor(Math.random() * (b - a + 1)) + a;
}
function formatTime(s) { return Math.floor(s/60) + ':' + ('0' + (s%60)).slice(-2); }
function fmtDate(ts) {
  var d = new Date(ts);
  return d.toLocaleDateString('en-GB', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' });
}
function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }
function opName(op) { return op.charAt(0).toUpperCase() + op.slice(1); }

// ================================================================
// CONFIG
// ================================================================
document.querySelectorAll('.dur-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    document.querySelectorAll('.dur-btn').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');
    duration = parseInt(btn.dataset.sec);
  });
});

function toggleOp(e, el) {
  if (e.target.tagName === 'INPUT') return;
  var op = el.dataset.op;
  if (selectedOps.has(op)) {
    if (selectedOps.size === 1) return;
    selectedOps.delete(op);
    el.classList.remove('active');
  } else {
    selectedOps.add(op);
    el.classList.add('active');
  }
}

// ================================================================
// QUESTION GENERATION
// ================================================================
function generateQuestion(opOverride, aOverride, bOverride) {
  var ops = opOverride ? [opOverride] : Array.from(selectedOps);
  var op = ops[Math.floor(Math.random() * ops.length)];
  var a, b, question, answer;

  if (op === 'addition') {
    a = aOverride !== undefined ? aOverride : randInt(document.getElementById('add-a1').value, document.getElementById('add-a2').value);
    b = bOverride !== undefined ? bOverride : randInt(document.getElementById('add-b1').value, document.getElementById('add-b2').value);
    question = a + ' + ' + b + ' ='; answer = a + b;
  } else if (op === 'subtraction') {
    a = aOverride !== undefined ? aOverride : randInt(document.getElementById('add-a1').value, document.getElementById('add-a2').value);
    b = bOverride !== undefined ? bOverride : randInt(document.getElementById('add-b1').value, document.getElementById('add-b2').value);
    while (a === b) { b = randInt(document.getElementById('add-b1').value, document.getElementById('add-b2').value); }
    var big = Math.max(a,b), small = Math.min(a,b);
    question = big + ' - ' + small + ' ='; answer = big - small; a = big; b = small;
  } else if (op === 'multiplication') {
    a = aOverride !== undefined ? aOverride : randInt(document.getElementById('mul-a1').value, document.getElementById('mul-a2').value);
    b = bOverride !== undefined ? bOverride : randInt(document.getElementById('mul-b1').value, document.getElementById('mul-b2').value);
    question = a + ' x ' + b + ' ='; answer = a * b;
  } else {
    a = aOverride !== undefined ? aOverride : randInt(document.getElementById('mul-a1').value, document.getElementById('mul-a2').value);
    b = bOverride !== undefined ? bOverride : randInt(document.getElementById('mul-b1').value, document.getElementById('mul-b2').value);
    question = (a * b) + ' ÷ ' + a + ' ='; answer = b;
  }
  return { question: question, answer: answer, op: op, a: a, b: b };
}

// ================================================================
// PACE BAR
// ================================================================
var paceVisible = true;
var paceRafId = null;
var _smoothedPct = 0, _smoothedDiff = 0, _lastDir = null;

function setPaceVisible(on) {
  paceVisible = on;
  document.getElementById('pace-wrap').classList.toggle('hidden', !on);
  try { localStorage.setItem('arith_pace', on ? '1' : '0'); } catch(e) {}
}

function loadPacePreference() {
  try {
    var v = localStorage.getItem('arith_pace');
    if (v === '0') {
      paceVisible = false;
      document.getElementById('pace-toggle').checked = false;
      document.getElementById('pace-wrap').classList.add('hidden');
    }
  } catch(e) {}
}

function updatePace() {
  if (!paceVisible || !accepting) return;
  var fill = document.getElementById('pace-fill');
  var num  = document.getElementById('pace-number');
  var lbl  = document.getElementById('pace-label');
  var avg  = opData[currentOp].count > 0 ? opData[currentOp].total / opData[currentOp].count : null;
  var elapsed = performance.now() - questionStartTime;

  if (!avg) {
    if (_lastDir !== 'noavg') {
      fill.style.width = '0%'; fill.className = 'pace-fill';
      num.className = 'pace-number no-avg'; lbl.textContent = 'no avg yet';
      _lastDir = 'noavg';
    }
    num.textContent = (elapsed / 1000).toFixed(1) + 's';
    paceRafId = requestAnimationFrame(updatePace);
    return;
  }

  lbl.textContent = 'vs avg (' + (avg / 1000).toFixed(1) + 's)';
  var diff = elapsed - avg;
  var targetPct = Math.min(Math.abs(diff) / avg, 1) * 50;
  _smoothedPct += (targetPct - _smoothedPct) * 0.18;
  _smoothedDiff += (diff - _smoothedDiff) * 0.18;

  var dir = diff > 0 ? 'behind' : 'ahead';
  if (dir !== _lastDir) {
    _smoothedPct = targetPct; _smoothedDiff = diff; _lastDir = dir;
  }

  var pct = _smoothedPct.toFixed(2) + '%';
  var diffSec = (_smoothedDiff / 1000).toFixed(1);

  if (dir === 'behind') {
    fill.className = 'pace-fill behind'; fill.style.left = '50%'; fill.style.right = ''; fill.style.width = pct;
    num.textContent = '+' + diffSec + 's'; num.className = 'pace-number behind';
  } else {
    fill.className = 'pace-fill ahead'; fill.style.right = '50%'; fill.style.left = ''; fill.style.width = pct;
    num.textContent = diffSec + 's'; num.className = 'pace-number ahead';
  }
  paceRafId = requestAnimationFrame(updatePace);
}

function startPaceTicker() {
  if (paceRafId) { cancelAnimationFrame(paceRafId); paceRafId = null; }
  _smoothedPct = 0; _smoothedDiff = 0; _lastDir = null;
  document.getElementById('pace-fill').style.width = '0%';
  document.getElementById('pace-fill').className = 'pace-fill';
  document.getElementById('pace-number').textContent = '';
  document.getElementById('pace-label').textContent = 'vs your avg';
  if (paceVisible) paceRafId = requestAnimationFrame(updatePace);
}

function stopPaceTicker() {
  if (paceRafId) { cancelAnimationFrame(paceRafId); paceRafId = null; }
}

// ================================================================
// MAIN GAME
// ================================================================
function startGame() {
  score = 0; troubleCount = 0; answeredQuestions = [];
  timeLeft = duration;
  for (var k in opData) { opData[k].total = 0; opData[k].count = 0; }

  document.getElementById('config-screen').style.display = 'none';
  document.getElementById('game-screen').style.display = 'flex';
  document.getElementById('score-display').textContent = '0';
  document.getElementById('timer-display').textContent = formatTime(timeLeft);

  var bar = document.getElementById('timer-bar');
  bar.style.transition = 'none'; bar.style.width = '100%';
  bar.offsetHeight;
  bar.style.transition = 'width 1s linear';

  nextQuestion();

  timerInterval = setInterval(function() {
    timeLeft--;
    document.getElementById('timer-display').textContent = formatTime(timeLeft);
    document.getElementById('timer-bar').style.width = (timeLeft / duration * 100) + '%';
    if (timeLeft <= 0) endGame();
  }, 1000);
}

function nextQuestion() {
  var q = generateQuestion();
  currentAnswer = q.answer; currentOp = q.op;
  currentQuestion = q.question; currentQA = q.a; currentQB = q.b;
  currentQuestionHadTrouble = false;
  questionStartTime = performance.now();
  document.getElementById('question-display').textContent = q.question;
  var inp = document.getElementById('answer-input');
  inp.value = ''; accepting = true; inp.focus();
  startPaceTicker();
}

function quitGame() {
  clearInterval(timerInterval); stopPaceTicker(); accepting = false;
  document.getElementById('game-screen').style.display = 'none';
  document.getElementById('config-screen').style.display = 'block';
  showPage('play');
}

document.getElementById('answer-input').addEventListener('keydown', function(e) {
  if (!accepting) return;
  if (e.key === 'Backspace' && !currentQuestionHadTrouble) {
    currentQuestionHadTrouble = true; troubleCount++;
  }
});

document.getElementById('answer-input').addEventListener('input', function() {
  if (!accepting) return;
  var val = this.value.trim();
  if (val === '' || val === '-') return;
  var typed = parseInt(val, 10);
  if (isNaN(typed)) return;
  if (typed === currentAnswer) {
    stopPaceTicker();
    var elapsed = performance.now() - questionStartTime;
    opData[currentOp].total += elapsed; opData[currentOp].count++;
    answeredQuestions.push({
      question: currentQuestion, answer: currentAnswer, op: currentOp,
      elapsed: elapsed, hadTrouble: currentQuestionHadTrouble, a: currentQA, b: currentQB
    });
    score++;
    document.getElementById('score-display').textContent = score;
    accepting = false;
    nextQuestion();
  }
});

// ================================================================
// END GAME
// ================================================================
function endGame() {
  clearInterval(timerInterval); stopPaceTicker(); accepting = false;

  var opAvg = {};
  for (var op in opData) {
    opAvg[op] = opData[op].count > 0 ? opData[op].total / opData[op].count : null;
  }

  var troublePool = [], seen = new Set();
  for (var i = 0; i < answeredQuestions.length; i++) {
    var q = answeredQuestions[i];
    var isSlow = opAvg[q.op] !== null && q.elapsed > 1.5 * opAvg[q.op];
    if ((q.hadTrouble || isSlow) && !seen.has(q.question)) {
      troublePool.push(Object.assign({}, q, { isSlow: isSlow }));
      seen.add(q.question);
    }
  }

  var data = loadData();
  var totalElapsed = 0;
  for (var j = 0; j < answeredQuestions.length; j++) totalElapsed += answeredQuestions[j].elapsed;
  var avgTime = answeredQuestions.length > 0 ? totalElapsed / answeredQuestions.length : 0;
  var total = score + troubleCount;
  var acc = total === 0 ? 100 : Math.round(score / total * 100);

  data.games.push({
    ts: Date.now(), duration: duration, score: score, trouble: troubleCount,
    acc: acc, avgTime: Math.round(avgTime), ops: Array.from(selectedOps),
    opAvg: (function() {
      var o = {};
      for (var k in opAvg) o[k] = opAvg[k] ? Math.round(opAvg[k]) : null;
      return o;
    })(),
    ranges: {
      addA: [parseInt(document.getElementById('add-a1').value), parseInt(document.getElementById('add-a2').value)],
      addB: [parseInt(document.getElementById('add-b1').value), parseInt(document.getElementById('add-b2').value)],
      mulA: [parseInt(document.getElementById('mul-a1').value), parseInt(document.getElementById('mul-a2').value)],
      mulB: [parseInt(document.getElementById('mul-b1').value), parseInt(document.getElementById('mul-b2').value)]
    },
    answered: answeredQuestions.map(function(q) { return { op: q.op, a: q.a, b: q.b }; })
  });

  for (var ti = 0; ti < troublePool.length; ti++) {
    var tq = troublePool[ti];
    if (!data.trouble[tq.question]) {
      data.trouble[tq.question] = { question: tq.question, answer: tq.answer, op: tq.op, a: tq.a, b: tq.b, count: 0, lastSeen: 0 };
    }
    data.trouble[tq.question].count++;
    data.trouble[tq.question].lastSeen = Date.now();
  }
  saveData(data);

  document.getElementById('game-screen').style.display = 'none';
  document.getElementById('config-screen').style.display = 'block';
  updateFirstTimeState();
  showPage('results');

  document.getElementById('final-score').textContent = score;
  document.getElementById('final-sub').textContent = 'correct answer' + (score !== 1 ? 's' : '') + ' in ' + formatTime(duration);
  document.getElementById('stat-correct').textContent = score;
  document.getElementById('stat-trouble').textContent = troublePool.length;
  document.getElementById('stat-acc').textContent = acc + '%';

  // Offer leaderboard submission (default settings only)
  var curRanges = {
    addA:[parseInt(document.getElementById('add-a1').value),parseInt(document.getElementById('add-a2').value)],
    addB:[parseInt(document.getElementById('add-b1').value),parseInt(document.getElementById('add-b2').value)],
    mulA:[parseInt(document.getElementById('mul-a1').value),parseInt(document.getElementById('mul-a2').value)],
    mulB:[parseInt(document.getElementById('mul-b1').value),parseInt(document.getElementById('mul-b2').value)]
  };
  if (isDefaultSettings({ ranges: curRanges, ops: Array.from(selectedOps) })) {
    showScoreModal(score, duration);
  }


  var practiceBtn = document.getElementById('practice-last-btn');
  practiceBtn._pool = troublePool;
  practiceBtn.disabled = troublePool.length === 0;
  practiceBtn.textContent = troublePool.length > 0 ? 'Practice mistakes (' + troublePool.length + ')' : 'No trouble!';

  buildResultChart();
}

