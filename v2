function renderPatterns() {
  var data = loadData();
  var patterns = buildPatterns(data.trouble);
  var list = document.getElementById('patterns-list'); list.innerHTML = '';
  var noP = document.getElementById('no-patterns');
  if (!patterns.length) {
    noP.style.display = 'block';
    noP.textContent = data.games.length < 2 ? 'Play at least 2 games to see patterns.' : 'No patterns yet - great work!';
    return;
  }
  noP.style.display = 'none';
  var maxCount = patterns[0].count;
  patterns.forEach(function(p) {
    var card = document.createElement('div'); card.className = 'pattern-card';
    var exChips = p.examples.map(function(ex) { return '<span class="pattern-ex-chip">' + ex.replace('=','').trim() + '</span>'; }).join('');
    card.innerHTML = '<div class="pattern-card-header"><div class="pattern-card-title">' + p.title + '</div><div class="pattern-card-count">' + '' + '</div></div><div class="pattern-bar-wrap"><div class="pattern-bar-fill" style="width:' + Math.round(p.count/maxCount*100) + '%"></div></div><div class="pattern-card-detail">' + p.detail + '</div><div class="pattern-template">' + p.template + '</div><div class="pattern-examples">' + exChips + '</div><button class="pattern-practice-btn">Practice this pattern</button>';
    card.querySelector('.pattern-practice-btn').addEventListener('click', function() { practicePattern(p.id); });
    list.appendChild(card);
  });
}

// ================================================================
// PRACTICE PAGE
// ================================================================
var _cachedPatterns = [];

function renderPracticeConfig() {
  var d = loadData();
  _cachedPatterns = buildPatterns(d.trouble);
  showPracticeConfig();
  var btn = document.getElementById('practice-start-btn');
  if (!_cachedPatterns.length) {
    btn.disabled = true; btn.textContent = 'No patterns yet';
  } else {
    btn.disabled = false; btn.textContent = 'Start practice';
  }
}

function showPracticeConfig() {
  document.getElementById('practice-config').style.display = 'block';
  document.getElementById('practice-game').style.display = 'none';
  document.getElementById('practice-done').style.display = 'none';
}

function practicePattern(pid) {
  var p = _cachedPatterns.find(function(x) { return x.id === pid; });
  if (!p) return;
  showPage('practice');
  setTimeout(function() { startPatternPractice(p); }, 50);
}

function startPatternPractice(p) {
  // Build exactly 20 questions: exact misses first, then generated similar
  var queue = [], seen = new Set();

  // Add the exact wrong questions first
  p.items.forEach(function(item) {
    if (!seen.has(item.question)) {
      queue.push({ question:item.question, answer:item.answer, op:item.op, a:item.a, b:item.b, tag:'Exact miss', similar:false });
      seen.add(item.question);
    }
  });

  // Fill up to 20 with generated questions following the pattern
  var attempts = 0;
  while (queue.length < 20 && attempts < 200) {
    attempts++;
    try {
      var sim = p.generateSimilar();
      if (sim && !seen.has(sim.question)) {
        queue.push(sim);
        seen.add(sim.question);
      }
    } catch(e) { break; }
  }

  // Shuffle and cap at 20
  queue = queue.sort(function() { return Math.random() - 0.5; }).slice(0, 20);

  _runPractice(queue.map(function(q) {
    return Object.assign({}, q, { _cleared:false, _failed:false, _seen:false });
  }));
}

function startPracticeSession() {
  // "Start practice" button — drills all patterns, 20 questions total
  if (!_cachedPatterns.length) return;
  var queue = [], seen = new Set();

  // One pass: exact misses from all patterns
  _cachedPatterns.forEach(function(p) {
    p.items.forEach(function(item) {
      if (!seen.has(item.question)) {
        queue.push({ question:item.question, answer:item.answer, op:item.op, a:item.a, b:item.b, tag:'Exact miss', similar:false });
        seen.add(item.question);
      }
    });
  });

  // Fill up to 20 with generated questions from random patterns
  var attempts = 0;
  while (queue.length < 20 && attempts < 300) {
    attempts++;
    var p = _cachedPatterns[Math.floor(Math.random() * _cachedPatterns.length)];
    try {
      var sim = p.generateSimilar();
      if (sim && !seen.has(sim.question)) { queue.push(sim); seen.add(sim.question); }
    } catch(e) {}
  }

  queue = queue.sort(function() { return Math.random() - 0.5; }).slice(0, 20);
  _runPractice(queue.map(function(q) {
    return Object.assign({}, q, { _cleared:false, _failed:false, _seen:false });
  }));
}


function showNextPractice() {
  var remaining = _practiceQueue.filter(function(q) { return !q._cleared; });
  var unseen = remaining.filter(function(q) { return !q._seen; });
  if (!unseen.length) {
    var failed = remaining.filter(function(q) { return q._failed; });
    if (failed.length) {
      failed.forEach(function(q) { q._failed = false; q._seen = false; });
      _practiceQueue = failed.sort(function() { return Math.random() - 0.5; });
      showNextPractice(); return;
    }
    document.getElementById('practice-game').style.display = 'none';
    document.getElementById('practice-done').style.display = 'block';
    document.getElementById('prac-done-score').textContent = _pracRight + '/' + _pracTotal;
    return;
  }
  var q = unseen[0]; q._seen = true;
  _pracCurrentAnswer = q.answer; _pracHadError = false; _practiceQueue._current = q;
  var idx = remaining.length - unseen.length + 1;
  var tagWrap = document.getElementById('practice-tag-wrap'); tagWrap.innerHTML = '';
  var t = document.createElement('span');
  t.className = 'practice-tag ' + (q.similar ? 'tag-similar' : 'tag-exact');
  t.textContent = q.tag || (q.similar ? 'Similar' : 'Exact miss');
  tagWrap.appendChild(t);
  document.getElementById('practice-question').textContent = q.question;
  document.getElementById('prac-progress').textContent = idx + '/' + remaining.length;
  document.getElementById('prac-remaining').textContent = remaining.length - idx;
  var inp = document.getElementById('practice-input'); inp.value = ''; inp.focus();
}

document.getElementById('practice-input').addEventListener('keydown', function(e) {
  if (e.key === 'Backspace' && !_pracHadError) {
    _pracHadError = true;
    if (_practiceQueue._current) _practiceQueue._current._failed = true;
  }
});

document.getElementById('practice-input').addEventListener('input', function() {
  var val = this.value.trim();
  if (val === '' || val === '-') return;
  var typed = parseInt(val, 10); if (isNaN(typed)) return;
  if (typed === _pracCurrentAnswer) {
    _pracTotal++;
    if (!_pracHadError && _practiceQueue._current) { _practiceQueue._current._cleared = true; _pracRight++; }
    showNextPractice();
  }
});

function endPracticeSession() {
  document.getElementById('practice-game').style.display = 'none';
  document.getElementById('practice-done').style.display = 'block';
  document.getElementById('prac-done-score').textContent = _pracRight + '/' + _pracTotal;
}

function _runPractice(items) {
  _practiceQueue = items.map(function(q) { return Object.assign({}, q, { _cleared: false, _failed: false, _seen: false }); });
  _pracRight = 0; _pracTotal = 0; _practiceQueue._current = null;
  document.getElementById('practice-config').style.display = 'none';
  document.getElementById('practice-game').style.display = 'flex';
  document.getElementById('practice-done').style.display = 'none';
  showNextPractice();
  document.getElementById('practice-input').focus();
}

