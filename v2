// INLINE RESULTS PRACTICE
// ================================================================
var _ipQueue = [], _ipCurrentAnswer = null, _ipHadError = false, _ipRight = 0, _ipTotal = 0;

function _runInlineResultsPractice(items) {
  _ipQueue = items.map(function(q) { return Object.assign({}, q, { _cleared: false, _failed: false, _seen: false }); });
  _ipRight = 0; _ipTotal = 0; _ipQueue._current = null;
  document.getElementById('inline-practice').style.display = 'block';
  document.getElementById('ip-done').style.display = 'none';
  document.getElementById('practice-last-btn').style.display = 'none';
  document.getElementById('ip-input').style.display = '';
  document.getElementById('ip-progress-wrap').style.display = '';
  _ipShowNext();
  document.getElementById('ip-input').focus();
}

function closeInlinePractice() {
  document.getElementById('inline-practice').style.display = 'none';
  document.getElementById('practice-last-btn').style.display = '';
}

function _ipShowNext() {
  var remaining = _ipQueue.filter(function(q) { return !q._cleared; });
  var unseen = remaining.filter(function(q) { return !q._seen; });
  if (!unseen.length) {
    var failed = remaining.filter(function(q) { return q._failed; });
    if (failed.length) {
      failed.forEach(function(q) { q._failed = false; q._seen = false; });
      _ipQueue = failed.sort(function() { return Math.random() - 0.5; });
      _ipShowNext(); return;
    }
    document.getElementById('ip-done').style.display = 'block';
    document.getElementById('ip-question').textContent = '';
    document.getElementById('ip-tag-wrap').innerHTML = '';
    document.getElementById('ip-done-score').textContent = _ipRight + '/' + _ipTotal;
    document.getElementById('ip-input').style.display = 'none';
    document.getElementById('ip-progress-wrap').style.display = 'none';
    return;
  }
  var q = unseen[0]; q._seen = true;
  _ipCurrentAnswer = q.answer; _ipHadError = false; _ipQueue._current = q;
  var idx = remaining.length - unseen.length + 1;
  var tagWrap = document.getElementById('ip-tag-wrap'); tagWrap.innerHTML = '';
  var t = document.createElement('span');
  t.className = 'practice-tag ' + (q.similar ? 'tag-similar' : 'tag-exact');
  t.textContent = q.tag || 'Trouble';
  tagWrap.appendChild(t);
  document.getElementById('ip-question').textContent = q.question;
  document.getElementById('ip-progress').textContent = idx + '/' + remaining.length;
  document.getElementById('ip-remaining').textContent = remaining.length - idx;
  var inp = document.getElementById('ip-input'); inp.value = ''; inp.focus();
}

document.getElementById('ip-input').addEventListener('keydown', function(e) {
  if (e.key === 'Backspace' && !_ipHadError) {
    _ipHadError = true;
    if (_ipQueue._current) _ipQueue._current._failed = true;
  }
});

document.getElementById('ip-input').addEventListener('input', function() {
  var val = this.value.trim();
  if (val === '' || val === '-') return;
  var typed = parseInt(val, 10); if (isNaN(typed)) return;
  if (typed === _ipCurrentAnswer) {
    _ipTotal++;
    if (!_ipHadError && _ipQueue._current) { _ipQueue._current._cleared = true; _ipRight++; }
    _ipShowNext();
  }
});

// Expose to window for inline onclick handlers
window.startGame = startGame;
window.quitGame = quitGame;
window.toggleOp = toggleOp;
window.stopProp = stopProp;
window.setPaceVisible = setPaceVisible;
window.setHistN = setHistN;
window.clearHistory = clearHistory;
window.startPracticeFromResults = startPracticeFromResults;
window.showPage = showPage;
window.startPracticeSession = startPracticeSession;
window.endPracticeSession = endPracticeSession;
window.showPracticeConfig = showPracticeConfig;
window.practicePattern = practicePattern;
window.closeInlinePractice = closeInlinePractice;
})();
