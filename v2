function renderHistory() {
  var data = loadData();
  var games = data.games.slice(-histN);
  var tbody = document.getElementById('history-tbody'); tbody.innerHTML = '';
  var noHist = document.getElementById('no-history');

  // All-time best banner
  var banner = document.getElementById('alltime-banner');
  if (data.games.length) {
