function buildResultChart() {
  var rows = document.getElementById('chart-rows'); rows.innerHTML = '';
  var opOrder = ['addition','subtraction','multiplication','division'];
  var avgs = opOrder.map(function(op) {
    return { op: op, symbol: opSymbols[op], count: opData[op].count, avg: opData[op].count > 0 ? opData[op].total / opData[op].count : null };
  });
  var withData = avgs.filter(function(d) { return d.avg !== null; });
  if (!withData.length) { rows.innerHTML = '<div class="chart-no-data">No completed questions.</div>'; return; }
  var maxAvg = Math.max.apply(null, withData.map(function(d) { return d.avg; }));
  var slowestOp = withData.reduce(function(a,b) { return a.avg > b.avg ? a : b; }).op;
  avgs.forEach(function(d) {
    var row = document.createElement('div'); row.className = 'chart-row';
    var lbl = document.createElement('div'); lbl.className = 'chart-op-label'; lbl.textContent = d.symbol;
    var track = document.createElement('div'); track.className = 'bar-track';
    var fill = document.createElement('div'); fill.className = 'bar-fill' + (d.op === slowestOp && withData.length > 1 ? ' slowest' : '');
    var tl = document.createElement('div'); tl.className = 'chart-time-label';
    var cl = document.createElement('div'); cl.className = 'chart-count';
    if (d.avg !== null) {
      tl.textContent = (d.avg/1000).toFixed(2) + 's'; cl.textContent = 'x' + d.count;
      (function(f, pct) { setTimeout(function() { f.style.width = pct + '%'; }, 50); })(fill, d.avg / maxAvg * 100);
    } else { tl.textContent = '-'; lbl.style.opacity = '0.3'; }
    track.appendChild(fill); row.appendChild(lbl); row.appendChild(track); row.appendChild(tl); row.appendChild(cl);
    rows.appendChild(row);
  });
}

function startPracticeFromResults() {
  var pool = document.getElementById('practice-last-btn')._pool || [];
  if (!pool.length) return;
  _runInlineResultsPractice(pool.map(function(q) { return Object.assign({}, q, { tag: q.hadTrouble ? 'Error' : 'Slow', similar: false }); }));
}

